<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>ブックノート — 読書メモ交換</title>
  <style>
    :root {
      --primary: #2d6a4f;
      --primary-light: #52b788;
      --primary-pale: #d8f3dc;
      --accent: #e76f51;
      --bg: #f4f6f3;
      --card-bg: #ffffff;
      --text: #1a1a2e;
      --text-secondary: #6c757d;
      --border: #e9ecef;
      --header-h: 56px;
      --nav-h: 64px;
      --radius: 16px;
      --shadow: 0 2px 12px rgba(0,0,0,0.07);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Yu Gothic UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      max-width: 480px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ===== HEADER ===== */
    #header {
      position: fixed;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 100%;
      max-width: 480px;
      height: var(--header-h);
      background: white;
      border-bottom: 1px solid var(--border);
      z-index: 100;
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
      padding: 0 16px;
    }
    .logo {
      font-size: 18px;
      font-weight: 800;
      color: var(--primary);
      letter-spacing: -0.5px;
    }
    .logo span { color: var(--accent); }
    .user-chip {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--primary-pale);
      padding: 4px 10px 4px 4px;
      border-radius: 20px;
      cursor: pointer;
    }
    .user-chip .av {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--primary);
      color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 800;
    }
    .user-chip span {
      font-size: 13px; font-weight: 700; color: var(--primary);
    }

    /* ===== MAIN ===== */
    #main {
      margin-top: var(--header-h);
      margin-bottom: var(--nav-h);
      min-height: calc(100vh - var(--header-h) - var(--nav-h));
    }
    .tab-content { display: none; padding: 12px; }
    .tab-content.active { display: block; }

    /* ===== BOTTOM NAV ===== */
    #bottomNav {
      position: fixed;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 100%; max-width: 480px;
      height: var(--nav-h);
      background: white;
      border-top: 1px solid var(--border);
      display: flex;
      z-index: 100;
      padding-bottom: env(safe-area-inset-bottom);
    }
    .nav-btn {
      flex: 1;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 2px;
      border: none; background: none; cursor: pointer;
      color: var(--text-secondary);
      transition: color 0.2s;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-btn.active { color: var(--primary); }
    .nav-icon { font-size: 22px; line-height: 1; }
    .nav-label { font-size: 11px; font-weight: 600; }
    .nav-btn.post-btn { position: relative; }
    .nav-post-circle {
      width: 46px; height: 46px;
      background: var(--primary);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; color: white; font-weight: 400;
      box-shadow: 0 4px 14px rgba(45,106,79,0.45);
      margin-bottom: 2px;
      line-height: 1;
    }
    .nav-post-label { font-size: 11px; font-weight: 600; color: var(--primary); }

    /* ===== FILTER BAR ===== */
    .filter-bar {
      display: flex; gap: 6px;
      overflow-x: auto; -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 8px;
    }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-chip {
      padding: 5px 13px;
      border-radius: 20px;
      border: 1.5px solid var(--border);
      font-size: 12px; font-weight: 600;
      white-space: nowrap; cursor: pointer;
      background: white; color: var(--text-secondary);
      font-family: inherit;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
      transition: all 0.15s;
    }
    .filter-chip.active {
      background: var(--primary); color: white; border-color: var(--primary);
    }

    /* ===== FEED CARDS ===== */
    .feed-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      margin-bottom: 12px;
      overflow: hidden;
    }
    .card-user-row {
      display: flex; align-items: center; gap: 8px;
      padding: 12px 14px 10px;
    }
    .user-avatar-sm {
      width: 34px; height: 34px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .user-info { flex: 1; min-width: 0; }
    .user-name { font-size: 13px; font-weight: 700; }
    .post-date { font-size: 11px; color: var(--text-secondary); margin-top: 1px; }
    .post-tag {
      font-size: 11px; font-weight: 700;
      padding: 3px 9px; border-radius: 20px;
      background: var(--primary-pale); color: var(--primary);
      flex-shrink: 0;
    }
    .mine-badge {
      font-size: 10px; background: var(--accent); color: white;
      padding: 1px 6px; border-radius: 8px; font-weight: 700;
      margin-left: 4px; vertical-align: middle;
    }

    .card-book-row {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 0 14px 12px;
    }
    .book-cover {
      width: 54px; height: 74px;
      border-radius: 5px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      box-shadow: 3px 3px 10px rgba(0,0,0,0.18);
    }
    .book-info { flex: 1; padding-top: 2px; }
    .book-title { font-size: 14px; font-weight: 800; line-height: 1.35; margin-bottom: 4px; }
    .book-author { font-size: 12px; color: var(--text-secondary); }

    .card-memo {
      padding: 10px 14px 12px;
      border-top: 1px solid var(--border);
    }
    .memo-quote {
      font-size: 11px; color: var(--primary); font-weight: 700;
      margin-bottom: 6px; letter-spacing: 0.3px;
    }
    .memo-text {
      font-size: 13px; line-height: 1.75; color: #333;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .memo-text.expanded {
      display: block;
    }
    .read-more-btn {
      display: inline-block; margin-top: 5px;
      font-size: 12px; color: var(--primary); font-weight: 600;
      cursor: pointer; background: none; border: none;
      padding: 0; font-family: inherit;
    }

    .card-actions {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 10px 10px;
      border-top: 1px solid var(--border);
    }
    .like-btn {
      display: flex; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--text-secondary); font-size: 13px; font-weight: 600;
      padding: 6px 10px; border-radius: 20px;
      transition: all 0.15s;
      -webkit-tap-highlight-color: transparent;
      font-family: inherit;
    }
    .like-btn.liked { color: #e63946; }
    .like-icon { font-size: 17px; transition: transform 0.2s; }
    .like-btn.liked .like-icon { animation: heartPop 0.3s ease; }
    .share-btn {
      display: flex; align-items: center; gap: 4px;
      background: none; border: none; cursor: pointer;
      color: var(--text-secondary); font-size: 12px; font-weight: 600;
      padding: 6px 10px; border-radius: 20px;
      font-family: inherit;
      -webkit-tap-highlight-color: transparent;
    }

    /* ===== SHELF ===== */
    .shelf-header { text-align: center; padding: 20px 0 10px; }
    .shelf-title { font-size: 18px; font-weight: 800; }
    .shelf-subtitle { font-size: 13px; color: var(--text-secondary); margin-top: 4px; }
    .shelf-empty {
      text-align: center; padding: 60px 24px;
      color: var(--text-secondary);
    }
    .shelf-empty-icon { font-size: 52px; margin-bottom: 14px; }
    .shelf-empty-text { font-size: 14px; line-height: 1.7; }
    .shelf-add-btn {
      margin-top: 20px;
      display: inline-block;
      background: var(--primary); color: white;
      padding: 11px 26px; border-radius: 24px;
      font-size: 14px; font-weight: 700;
      cursor: pointer; border: none; font-family: inherit;
    }
    .shelf-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
      margin-top: 6px;
    }
    .shelf-card {
      background: white; border-radius: 12px;
      box-shadow: var(--shadow); padding: 12px; cursor: pointer;
    }
    .shelf-cover {
      width: 100%; height: 80px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; margin-bottom: 8px;
    }
    .shelf-book-title {
      font-size: 13px; font-weight: 800; line-height: 1.3; margin-bottom: 2px;
      overflow: hidden; display: -webkit-box;
      -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    }
    .shelf-book-author { font-size: 11px; color: var(--text-secondary); }
    .shelf-book-tag {
      display: inline-block; margin-top: 6px;
      font-size: 10px; font-weight: 700;
      padding: 2px 7px; border-radius: 10px;
      background: var(--primary-pale); color: var(--primary);
    }

    /* ===== MODAL ===== */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.55); z-index: 200;
      display: flex; align-items: flex-end; justify-content: center;
    }
    .modal-overlay.hidden { display: none; }
    .modal-sheet {
      background: white; width: 100%; max-width: 480px;
      border-radius: 22px 22px 0 0;
      max-height: 92vh; overflow-y: auto;
      padding-bottom: calc(16px + env(safe-area-inset-bottom));
    }
    .modal-handle {
      width: 36px; height: 4px; background: #ddd;
      border-radius: 2px; margin: 12px auto 0;
    }
    .modal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 16px 12px;
      border-bottom: 1px solid var(--border);
    }
    .modal-title { font-size: 17px; font-weight: 800; }
    .modal-close {
      background: none; border: none; font-size: 20px;
      cursor: pointer; color: var(--text-secondary); padding: 4px;
    }
    .modal-body { padding: 16px; }

    .form-group { margin-bottom: 16px; }
    .form-label {
      display: block; font-size: 12px; font-weight: 800;
      color: var(--text-secondary); margin-bottom: 6px;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    .form-label .req { color: var(--accent); }
    .form-input, .form-textarea {
      width: 100%; padding: 11px 13px;
      border: 1.5px solid var(--border); border-radius: 10px;
      font-size: 15px; font-family: inherit; outline: none;
      transition: border-color 0.2s; color: var(--text);
      background: white;
    }
    .form-input:focus, .form-textarea:focus { border-color: var(--primary); }
    .form-textarea { resize: none; min-height: 130px; line-height: 1.6; }

    .tag-selector { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag-chip {
      padding: 5px 13px; border-radius: 16px;
      border: 1.5px solid var(--border);
      font-size: 13px; cursor: pointer;
      background: white; font-family: inherit;
      transition: all 0.15s; color: var(--text-secondary);
      -webkit-tap-highlight-color: transparent;
    }
    .tag-chip.selected {
      background: var(--primary); color: white; border-color: var(--primary);
    }

    .submit-btn {
      width: 100%; padding: 14px;
      background: var(--primary); color: white;
      border: none; border-radius: 12px;
      font-size: 16px; font-weight: 800;
      cursor: pointer; font-family: inherit; margin-top: 8px;
      transition: opacity 0.2s;
    }
    .submit-btn:active { opacity: 0.8; }

    /* ===== DETAIL MODAL ===== */
    .detail-book-row {
      display: flex; align-items: center; gap: 14px;
      padding: 16px; border-bottom: 1px solid var(--border);
    }
    .detail-cover {
      width: 60px; height: 82px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px;
      box-shadow: 3px 3px 10px rgba(0,0,0,0.18);
      flex-shrink: 0;
    }
    .detail-book-title { font-size: 16px; font-weight: 800; margin-bottom: 4px; }
    .detail-book-author { font-size: 13px; color: var(--text-secondary); margin-bottom: 6px; }
    .detail-meta { display: flex; gap: 6px; flex-wrap: wrap; }
    .detail-memo {
      padding: 16px; font-size: 14px; line-height: 1.85;
      color: #333; white-space: pre-wrap;
    }
    .detail-actions {
      padding: 8px 16px 16px;
      display: flex; gap: 8px;
    }
    .detail-delete-btn {
      flex: 1; padding: 11px;
      background: #fff5f5; color: #e63946;
      border: 1.5px solid #ffc9c9; border-radius: 10px;
      font-size: 14px; font-weight: 700; cursor: pointer;
      font-family: inherit;
    }

    /* ===== TOAST ===== */
    .toast {
      position: fixed;
      bottom: calc(var(--nav-h) + 16px);
      left: 50%; transform: translateX(-50%) translateY(20px);
      background: #1a1a2e; color: white;
      padding: 10px 22px; border-radius: 24px;
      font-size: 14px; font-weight: 600;
      opacity: 0; transition: all 0.3s;
      z-index: 300; white-space: nowrap; pointer-events: none;
    }
    .toast.show {
      opacity: 1; transform: translateX(-50%) translateY(0);
    }

    /* ===== ANIMATIONS ===== */
    @keyframes heartPop {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1); }
    }

    /* ===== EMPTY FEED ===== */
    .empty-state {
      text-align: center; padding: 60px 20px;
      color: var(--text-secondary);
    }
    .empty-state-icon { font-size: 48px; margin-bottom: 12px; }
    .empty-state-text { font-size: 14px; line-height: 1.7; }
  </style>
</head>
<body>

<div id="app">

  <!-- ===== HEADER ===== -->
  <header id="header">
    <div class="header-inner">
      <div class="logo">📚 ブック<span>ノート</span></div>
      <div class="user-chip">
        <div class="av" id="userAv">TK</div>
        <span id="userName">TK</span>
      </div>
    </div>
  </header>

  <!-- ===== MAIN ===== -->
  <main id="main">

    <!-- フィード -->
    <section id="tabFeed" class="tab-content active">
      <div class="filter-bar" id="filterBar"></div>
      <div id="feedList"></div>
    </section>

    <!-- 本棚 -->
    <section id="tabShelf" class="tab-content">
      <div class="shelf-header">
        <div class="shelf-title">📖 TKの本棚</div>
        <div class="shelf-subtitle" id="shelfSubtitle">0冊</div>
      </div>
      <div id="shelfContent"></div>
    </section>

  </main>

  <!-- ===== BOTTOM NAV ===== -->
  <nav id="bottomNav">
    <button class="nav-btn active" id="navFeed" onclick="switchTab('feed')">
      <span class="nav-icon">🏠</span>
      <span class="nav-label">フィード</span>
    </button>
    <button class="nav-btn post-btn" onclick="showPostModal()">
      <div class="nav-post-circle">＋</div>
      <span class="nav-post-label">投稿</span>
    </button>
    <button class="nav-btn" id="navShelf" onclick="switchTab('shelf')">
      <span class="nav-icon">📖</span>
      <span class="nav-label">本棚</span>
    </button>
  </nav>

</div>

<!-- ===== POST MODAL ===== -->
<div class="modal-overlay hidden" id="postModal">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <div class="modal-title">📝 読書メモを投稿</div>
      <button class="modal-close" onclick="hidePostModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">本のタイトル <span class="req">*</span></label>
        <input class="form-input" id="fTitle" type="text" placeholder="例：ゼロ・トゥ・ワン">
      </div>
      <div class="form-group">
        <label class="form-label">著者名</label>
        <input class="form-input" id="fAuthor" type="text" placeholder="例：ピーター・ティール">
      </div>
      <div class="form-group">
        <label class="form-label">カテゴリ</label>
        <div class="tag-selector" id="tagSelector"></div>
      </div>
      <div class="form-group">
        <label class="form-label">学び・気づき <span class="req">*</span></label>
        <textarea class="form-textarea" id="fMemo" placeholder="この本から得た気づき・印象に残った言葉・実践したいことを書いてみよう&#10;&#10;「量より質」ではなく「質を上げるために量をこなす」という考え方に目から鱗が落ちた…"></textarea>
      </div>
      <button class="submit-btn" onclick="submitPost()">投稿する 🚀</button>
    </div>
  </div>
</div>

<!-- ===== DETAIL MODAL ===== -->
<div class="modal-overlay hidden" id="detailModal">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <div class="modal-title" id="detailTitle">詳細</div>
      <button class="modal-close" onclick="hideDetailModal()">✕</button>
    </div>
    <div id="detailBody"></div>
  </div>
</div>

<!-- ===== TOAST ===== -->
<div class="toast" id="toast"></div>

<script>
// =============================================
// 定数
// =============================================
const TAGS = ['ビジネス', '自己啓発', '哲学', '経済', '心理', '科学', '小説', 'その他'];

const COVER_COLORS = [
  ['#2d6a4f', '#b7e4c7'],
  ['#457b9d', '#a8dadc'],
  ['#6d4c7d', '#e9d8fd'],
  ['#e76f51', '#ffddd2'],
  ['#f4a261', '#fef3c7'],
  ['#2b6cb0', '#bee3f8'],
  ['#c77dff', '#f0e6ff'],
  ['#386641', '#c7efcf'],
];

function getCoverColors(str) {
  let h = 0;
  for (const c of String(str)) h = (h << 5) - h + c.charCodeAt(0);
  return COVER_COLORS[Math.abs(h) % COVER_COLORS.length];
}

// =============================================
// デモデータ（8投稿 × 5ユーザー）
// =============================================
const DEMO = [
  {
    id: 'd1',
    user: { name: '葵', emoji: '🌿', bg: '#d8f3dc' },
