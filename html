    tag: '哲学',
    memo: 'アドラー心理学の入門書。「人の悩みは全て対人関係の悩みである」という命題から始まり、課題の分離・承認欲求からの解放へと展開する。\n\n「他者の期待を満たすために生きてはいけない」という言葉、頭では分かっていたけど腑に落ちたのは初めてかも。自分の課題と他人の課題を分ける実践が地味に難しくて面白い。',
    date: '2026-05-09', likes: 42
  },
  {
    id: 'd7',
    user: { name: '健人', emoji: '⚡', bg: '#ffddd2' },
    book: { title: '１分で話せ', author: '伊藤羊一' },
    tag: 'ビジネス',
    memo: 'プレゼンは相手の頭の中にYESを作ること、という定義から入る実践的な本。「人は論理では動かない、感情で動いて論理で正当化する」というのが刺さった。\n\n上司への提案が通らないのは、自分が論理ばかり並べていたからかも。感情への働きかけをもっと意識する。',
    date: '2026-05-08', likes: 19
  },
  {
    id: 'd8',
    user: { name: '美沙', emoji: '🌸', bg: '#f0e6ff' },
    book: { title: 'アウトプット大全', author: '樺沢紫苑' },
    tag: '自己啓発',
    memo: 'インプット3：アウトプット7が理想比率、というのが一番の収穫。本ばかり読んで「分かった気」になるのが一番やばいパターンだと自覚した。\n\n読んだら必ずメモ→SNSでシェア→人に話す、の3ステップを実践中。このノートを書くのもその一環。書くことで本当に理解しているかが分かる。',
    date: '2026-05-06', likes: 33
  },
];

// =============================================
// 状態
// =============================================
let currentTab   = 'feed';
let currentFilter = 'すべて';
let selectedTag  = '';
let likedIds     = JSON.parse(localStorage.getItem('bn_liked') || '[]');
let userNotes    = JSON.parse(localStorage.getItem('bn_notes') || '[]');
let detailNoteId = null;

// =============================================
// タブ切り替え
// =============================================
function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('active'));
  const tabEl = document.getElementById('tab' + cap(tab));
  const navEl = document.getElementById('nav' + cap(tab));
  if (tabEl) tabEl.classList.add('active');
  if (navEl) navEl.classList.add('active');
  if (tab === 'feed') renderFeed();
  if (tab === 'shelf') renderShelf();
}

function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

// =============================================
// フィード
// =============================================
function getAllNotes() {
  const myNotes = userNotes.map(n => ({ ...n, isOwn: true }));
  const demos   = DEMO.map(n => ({ ...n, isOwn: false }));
  return [...myNotes, ...demos].sort((a, b) => b.date.localeCompare(a.date));
}

function renderFeed() {
  // フィルターバー
  const filters = ['すべて', ...TAGS];
  document.getElementById('filterBar').innerHTML = filters.map(f =>
    `<button class="filter-chip${currentFilter === f ? ' active' : ''}" onclick="setFilter('${f}')">${f}</button>`
  ).join('');

  // ノート一覧
  const notes = getAllNotes().filter(n => currentFilter === 'すべて' || n.tag === currentFilter);
  const el = document.getElementById('feedList');

  if (notes.length === 0) {
    el.innerHTML = `<div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">このカテゴリにはまだ投稿がありません。<br>最初の一件を投稿してみよう！</div></div>`;
    return;
  }
  el.innerHTML = notes.map(n => buildCard(n)).join('');
}

function buildCard(n) {
  const [bg] = getCoverColors(n.book.title);
  const isLiked = likedIds.includes(n.id);
  const likeCount = n.likes + (isLiked ? 1 : 0);
  const longMemo = n.memo.length > 100;

  return `
    <div class="feed-card" id="card-${n.id}">
      <div class="card-user-row">
        <div class="user-avatar-sm" style="background:${n.user.bg}">${n.user.emoji}</div>
        <div class="user-info">
          <div class="user-name">${esc(n.user.name)}${n.isOwn ? '<span class="mine-badge">自分</span>' : ''}</div>
          <div class="post-date">${fmtDate(n.date)}</div>
        </div>
        <span class="post-tag">${esc(n.tag || 'その他')}</span>
      </div>
      <div class="card-book-row">
        <div class="book-cover" style="background:${bg}">📖</div>
        <div class="book-info">
          <div class="book-title">${esc(n.book.title)}</div>
          <div class="book-author">${esc(n.book.author || '著者不明')}</div>
        </div>
      </div>
      <div class="card-memo">
        <div class="memo-quote">💬 読書メモ</div>
        <div class="memo-text" id="mt-${n.id}">${esc(n.memo)}</div>
        ${longMemo ? `<button class="read-more-btn" id="rmb-${n.id}" onclick="toggleMemo('${n.id}')">もっと見る ▼</button>` : ''}
      </div>
      <div class="card-actions">
        <button class="like-btn${isLiked ? ' liked' : ''}" id="like-${n.id}" onclick="toggleLike('${n.id}', ${n.likes})">
          <span class="like-icon">${isLiked ? '❤️' : '🤍'}</span>
          <span id="lc-${n.id}">${likeCount}</span>
        </button>
        <button class="share-btn" onclick="shareNote('${n.id}')">↗ シェア</button>
      </div>
    </div>
  `;
}

function setFilter(f) {
  currentFilter = f;
  renderFeed();
}

function toggleMemo(id) {
  const mt  = document.getElementById(`mt-${id}`);
  const btn = document.getElementById(`rmb-${id}`);
  const exp = mt.classList.toggle('expanded');
  btn.textContent = exp ? '閉じる ▲' : 'もっと見る ▼';
}

function toggleLike(id, _base) {
  const btn  = document.getElementById(`like-${id}`);
  const icon = btn.querySelector('.like-icon');
  const cnt  = document.getElementById(`lc-${id}`);
  const cur  = parseInt(cnt.textContent);

  if (likedIds.includes(id)) {
    likedIds = likedIds.filter(i => i !== id);
    btn.classList.remove('liked');
    icon.textContent = '🤍';
    cnt.textContent = cur - 1;
  } else {
    likedIds.push(id);
    btn.classList.add('liked');
    icon.textContent = '❤️';
    cnt.textContent = cur + 1;
  }
  localStorage.setItem('bn_liked', JSON.stringify(likedIds));
}

function shareNote(id) {
  const note = [...DEMO, ...userNotes].find(n => n.id === id);
  if (!note) return;
  const text = `📚「${note.book.title}」より\n\n${note.memo.slice(0, 120)}${note.memo.length > 120 ? '…' : ''}\n\n#ブックノート`;
  if (navigator.share) {
    navigator.share({ text }).catch(() => {});
  } else {
    navigator.clipboard.writeText(text).then(() => showToast('📋 クリップボードにコピーしました'));
  }
}

// =============================================
// 本棚
// =============================================
function renderShelf() {
  const notes = userNotes;
  document.getElementById('shelfSubtitle').textContent = `${notes.length}冊`;
  const el = document.getElementById('shelfContent');

  if (notes.length === 0) {
    el.innerHTML = `
      <div class="shelf-empty">
        <div class="shelf-empty-icon">📚</div>
        <div class="shelf-empty-text">まだ本棚に本がありません。<br>最初の読書メモを投稿してみよう！</div>
        <button class="shelf-add-btn" onclick="showPostModal()">＋ 投稿する</button>
      </div>`;
    return;
  }

  el.innerHTML = `
    <div class="shelf-grid">
      ${notes.map(n => {
        const [bg] = getCoverColors(n.book.title);
        return `
          <div class="shelf-card" onclick="showDetail('${n.id}')">
            <div class="shelf-cover" style="background:${bg}">📖</div>
            <div class="shelf-book-title">${esc(n.book.title)}</div>
            <div class="shelf-book-author">${esc(n.book.author || '著者不明')}</div>
            <span class="shelf-book-tag">${esc(n.tag || 'その他')}</span>
          </div>`;
      }).join('')}
    </div>`;
}

function showDetail(id) {
  const note = userNotes.find(n => n.id === id);
  if (!note) return;
  detailNoteId = id;
  const [bg] = getCoverColors(note.book.title);
  document.getElementById('detailTitle').textContent = '📖 ' + note.book.title;
  document.getElementById('detailBody').innerHTML = `
    <div class="detail-book-row">
      <div class="detail-cover" style="background:${bg}">📖</div>
      <div>
        <div class="detail-book-title">${esc(note.book.title)}</div>
        <div class="detail-book-author">${esc(note.book.author || '著者不明')}</div>
        <div class="detail-meta">
          <span class="shelf-book-tag">${esc(note.tag || 'その他')}</span>
          <span style="font-size:11px;color:var(--text-secondary);padding-top:3px;">${fmtDate(note.date)}</span>
        </div>
      </div>
    </div>
    <div class="detail-memo">${esc(note.memo)}</div>
    <div class="detail-actions">
      <button class="detail-delete-btn" onclick="deleteNote('${id}')">🗑 削除する</button>
    </div>`;
  document.getElementById('detailModal').classList.remove('hidden');
}

function deleteNote(id) {
  if (!confirm('このメモを削除しますか？')) return;
  userNotes = userNotes.filter(n => n.id !== id);
  localStorage.setItem('bn_notes', JSON.stringify(userNotes));
  hideDetailModal();
  renderShelf();
  showToast('🗑 削除しました');
}

function hideDetailModal() {
  document.getElementById('detailModal').classList.add('hidden');
  detailNoteId = null;
}

// =============================================
// 投稿モーダル
// =============================================
function showPostModal() {
  selectedTag = '';
  document.getElementById('fTitle').value  = '';
  document.getElementById('fAuthor').value = '';
  document.getElementById('fMemo').value   = '';
  document.getElementById('tagSelector').innerHTML = TAGS.map(t =>
    `<button class="tag-chip" onclick="pickTag('${t}',this)">${t}</button>`
  ).join('');
  document.getElementById('postModal').classList.remove('hidden');
  setTimeout(() => document.getElementById('fTitle').focus(), 100);
}

function hidePostModal() {
  document.getElementById('postModal').classList.add('hidden');
}

function pickTag(tag, el) {
  selectedTag = tag;
  document.querySelectorAll('#tagSelector .tag-chip').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}

function submitPost() {
  const title  = document.getElementById('fTitle').value.trim();
  const author = document.getElementById('fAuthor').value.trim();
  const memo   = document.getElementById('fMemo').value.trim();

  if (!title) { showToast('📚 本のタイトルを入力してください'); return; }
  if (!memo)  { showToast('💭 学び・気づきを入力してください'); return; }

  const note = {
    id: 'u' + Date.now(),
    user: { name: 'TK', emoji: '🚀', bg: '#d8f3dc' },
    book: { title, author },
    tag: selectedTag || 'その他',
    memo,
    date: new Date().toISOString().split('T')[0],
    likes: 0,
  };

  userNotes.unshift(note);
  localStorage.setItem('bn_notes', JSON.stringify(userNotes));
  hidePostModal();
  showToast('🎉 投稿しました！');
  if (currentTab === 'shelf') renderShelf();
  switchTab('feed');
}

// =============================================
// ユーティリティ
// =============================================
function fmtDate(d) {
  const date = new Date(d);
  const diff = Math.floor((Date.now() - date) / 86400000);
  if (diff === 0) return '今日';
  if (diff === 1) return '昨日';
  if (diff < 7)  return `${diff}日前`;
  return `${date.getMonth()+1}/${date.getDate()}`;
}

function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/\n/g,'<br>');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

// =============================================
// 初期化
// =============================================
renderFeed();
</script>
